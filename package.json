{
  "name": "vite-plugin-routes",
  "type": "module",
  "version": "0.1.0",
  "description": "File based typed routing for Vue Router",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/vite-plugin-routes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/vite-plugin-routes.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/vite-plugin-routes/issues"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "vue-router",
    "pages",
    "filesystem",
    "types",
    "typed",
    "vue",
    "nuxt",
    "router"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./vite": {
      "import": "./dist/vite.js"
    },
    "./webpack": {
      "import": "./dist/webpack.js"
    },
    "./rollup": {
      "import": "./dist/rollup.js"
    },
    "./esbuild": {
      "import": "./dist/esbuild.js"
    },
    "./options": {
      "import": "./dist/options.js"
    },
    "./runtime": {
      "import": "./dist/runtime.js"
    },
    "./data-loaders": {
      "import": "./dist/data-loaders/index.js"
    },
    "./data-loaders/basic": {
      "import": "./dist/data-loaders/basic.js"
    },
    "./data-loaders/pinia-colada": {
      "import": "./dist/data-loaders/pinia-colada.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "data-loaders": [
        "./dist/data-loaders/index.d.ts"
      ],
      "data-loaders/basic": [
        "./dist/data-loaders/basic.d.ts"
      ],
      "data-loaders/pinia-colada": [
        "./dist/data-loaders/pinia-colada.d.ts"
      ],
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "client.d.ts",
    "dist",
    "route.schema.json"
  ],
  "scripts": {
    "build": "bun --bun build.ts",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "changelog": "bunx changelogen --output CHANGELOG.md",
    "prepublishOnly": "bun --bun run build",
    "release": "bun run changelog && bunx bumpp package.json ./packages/vite-plugin-layouts/package.json --all",
    "test": "vitest run",
    "typecheck": "bun --bun tsc --noEmit",
    "dev:docs": "bun --bun vitepress dev docs",
    "build:docs": "bun --bun vitepress build docs",
    "preview:docs": "bun --bun vitepress preview docs",
    "example:dev": "bun --bun -C examples/spa run dev",
    "example:build": "bun --bun -C examples/spa run build",
    "example:serve": "bun --bun -C examples/spa run serve",
    "example:build-ssg": "bun --bun -C examples/ssg run build",
    "example:serve-ssg": "bun --bun -C examples/ssg run serve"
  },
  "peerDependencies": {
    "vue-router": "^4.4.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@vue-macros/common": "3.1.2",
    "ast-walker-scope": "^0.9.0",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "json5": "^2.2.3",
    "local-pkg": "^1.2.1",
    "magic-string": "^0.30.21",
    "mlly": "^1.8.2",
    "pathe": "^2.0.3",
    "picomatch": "^4.0.4",
    "scule": "^1.3.0",
    "unplugin": "^2.3.11",
    "unplugin-utils": "^0.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@pinia/colada": "^1.3.1",
    "@shikijs/vitepress-twoslash": "4.1.0",
    "@stacksjs/docs": "^0.70.45",
    "@tanstack/vue-query": "^5.100.14",
    "@types/bun": "^1.3.14",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@vue/language-core": "^3.3.1",
    "@vue/test-utils": "^2.4.10",
    "bun-plugin-dtsx": "^0.9.26",
    "chalk": "^5.6.2",
    "conventional-changelog-cli": "^5.0.0",
    "execa": "^9.6.1",
    "firebase": "^11.10.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^16.4.0",
    "minimist": "^1.2.8",
    "nodemon": "^3.1.14",
    "p-series": "^3.0.0",
    "pinia": "^3.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "semver": "^7.8.1",
    "ts-expect": "^1.3.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-vue-markdown": "^28.3.1",
    "vite": "^6.4.2",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.13.0",
    "vitest": "^3.2.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4",
    "vue-router-mock": "^1.1.0",
    "vue-tsc": "^2.2.12",
    "vuefire": "^3.2.3",
    "yorkie": "^2.0.0"
  }
}
